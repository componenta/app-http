{
    "name": "componenta/app-http",
    "description": "HTTP runtime integration for Componenta applications",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "componenta/app": "^1.0",
        "componenta/config": "^1.0",
        "componenta/http-emitter": "^1.0",
        "componenta/http-psr": "^1.0",
        "componenta/middleware-factory": "^1.0",
        "componenta/path-resolver": "^1.0",
        "componenta/pipeline": "^1.0",
        "componenta/scope": "^1.0",
        "nyholm/psr7-server": "^1.1",
        "psr/container": "^2.0",
        "psr/http-server-middleware": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Componenta\\App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Componenta\\App\\Server\\Tests\\": "tests/"
        }
    },
    "extra": {
        "componenta": {
            "config-providers": [
                "Componenta\\App\\Server\\ConfigProvider"
            ]
        }
    },
    "minimum-stability": "stable"
}
